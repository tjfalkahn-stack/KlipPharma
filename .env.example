OPENAI_API_KEY=
PORT=3100
AI_TEXT_MODEL=gpt-4o-mini
AI_TRANSCRIPTION_MODEL=whisper-1

# Local development defaults to one private local owner with no sign-in screen.
# For production, set AUTH_MODE=required and add a PostgreSQL connection string.
AUTH_MODE=off
DATABASE_URL=
PGSSLMODE=require
DB_POOL_SIZE=10
SESSION_DAYS=30
NODE_ENV=development
STORAGE_ROOT=

# Optional private Cloudflare R2 direct uploads. Set all five in production.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
